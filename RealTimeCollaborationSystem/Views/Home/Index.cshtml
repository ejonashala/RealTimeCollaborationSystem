@using RealTimeCollaborationSystem.Services.Interfaces
@inject ITranslationService T

@{
    ViewData["Title"] = "CollabSpace";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<div class="home-page">
    <section class="hero-section">
        <div class="home-shell">
            <div class="hero-banner">
                <div class="hero-grid">
                    <div class="hero-copy">
                        <span class="hero-eyebrow">@T.T("Real-time academic collaboration platform")</span>
                        <h1>@T.T("CollabSpace brings students and professors into one structured, live academic workspace.")</h1>
                        <p class="hero-subtitle">
                            @T.T("Manage project topics, tasks, quizzes, teamwork, progress, and professor-student coordination in a platform designed for clarity and real-time momentum.")
                        </p>

                        <div class="hero-actions">
                            <a class="home-btn home-btn--primary" href="#features">@T.T("Explore Features")</a>
                            <a class="home-btn home-btn--secondary" href="#workflow">@T.T("See How It Works")</a>
                        </div>

                        <div class="hero-proof" aria-label="Platform qualities">
                            <article class="hero-proof__item">
                                <strong>@T.T("Role-aware coordination")</strong>
                                <span>@T.T("Designed for both students and professors")</span>
                            </article>
                            <article class="hero-proof__item">
                                <strong>@T.T("Live academic workflow")</strong>
                                <span>@T.T("Tasks, progress, and updates stay connected")</span>
                            </article>
                        </div>

                        <div class="hero-highlights" aria-label="Platform highlights">
                            <span>@T.T("Built for students and professors")</span>
                            <span>@T.T("Organized academic workflow")</span>
                            <span>@T.T("Live updates and shared progress")</span>
                        </div>
                    </div>

                    <div class="hero-visual" aria-hidden="true">
                        <div class="workspace-panel">
                            <div class="workspace-panel__chrome">
                                <div class="workspace-panel__lights">
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                </div>
                                <span class="workspace-panel__id">@T.T("CollabSpace Workspace")</span>
                            </div>

                            <div class="workspace-panel__top">
                                <div>
                                    <span class="workspace-panel__eyebrow">@T.T("Workspace preview")</span>
                                    <h2>@T.T("Academic coordination, in one place")</h2>
                                </div>
                                <span class="status-pill">@T.T("Live sync")</span>
                            </div>

                            <div class="workspace-metrics">
                                <article class="workspace-metric">
                                    <span>@T.T("Realtime")</span>
                                    <strong>@T.T("Team activity")</strong>
                                </article>
                                <article class="workspace-metric">
                                    <span>@T.T("Structured")</span>
                                    <strong>@T.T("Task flow")</strong>
                                </article>
                                <article class="workspace-metric">
                                    <span>@T.T("Visible")</span>
                                    <strong>@T.T("Progress + feedback")</strong>
                                </article>
                            </div>

                            <div class="workspace-board">
                                <div class="workspace-board__primary">
                                    <div class="workspace-panel__lead">
                                        <strong>@T.T("One organized view for collaboration, planning, and progress.")</strong>
                                        <p>@T.T("CollabSpace keeps topic decisions, tasks, guidance, quizzes, and updates in one connected academic environment.")</p>
                                    </div>

                                    <div class="workspace-list">
                                        <div class="workspace-list__item">
                                            <span class="workspace-list__dot"></span>
                                            <div>
                                                <strong>@T.T("Real-time teamwork spaces")</strong>
                                                <p>@T.T("Shared work remains visible while groups collaborate and adjust quickly.")</p>
                                            </div>
                                        </div>

                                        <div class="workspace-list__item">
                                            <span class="workspace-list__dot"></span>
                                            <div>
                                                <strong>@T.T("Tasks, topics, and quizzes")</strong>
                                                <p>@T.T("Academic work stays structured from early planning through evaluation.")</p>
                                            </div>
                                        </div>

                                        <div class="workspace-list__item">
                                            <span class="workspace-list__dot"></span>
                                            <div>
                                                <strong>@T.T("Role-based guidance and visibility")</strong>
                                                <p>@T.T("Students and professors get the clarity they need without added noise.")</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="workspace-board__side">
                                    <article class="workspace-sidecard">
                                        <span class="workspace-sidecard__label">@T.T("Current focus")</span>
                                        <strong>@T.T("Project alignment")</strong>
                                        <p>@T.T("Topic review, task assignment, and professor feedback remain synchronized.")</p>
                                        <div class="workspace-sidecard__progress">
                                            <span style="width: 74%;"></span>
                                        </div>
                                    </article>

                                    <article class="workspace-sidecard workspace-sidecard--soft">
                                        <span class="workspace-sidecard__label">@T.T("Today")</span>
                                        <ul class="workspace-sidecard__list">
                                            <li>@T.T("Task updates published live")</li>
                                            <li>@T.T("Quiz checkpoints ready")</li>
                                            <li>@T.T("Professor guidance attached to work")</li>
                                        </ul>
                                    </article>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section-block section-block--features" id="features">
        <div class="home-shell">
            <div class="section-heading">
                <span class="section-kicker">@T.T("Core capabilities")</span>
                <h2>@T.T("A curated feature set built around the way academic collaboration actually works.")</h2>
                <p>@T.T("Instead of scattered tools and disconnected actions, CollabSpace organizes the most important parts of academic teamwork into a clear, focused experience.")</p>
            </div>

            <div class="feature-layout">
                <article class="feature-spotlight feature-spotlight--wide">
                    <span class="feature-spotlight__kicker">@T.T("Live collaboration")</span>
                    <h3>@T.T("Coordinate teamwork in real time without losing structure.")</h3>
                    <p>@T.T("Students and professors can follow activity as it happens while keeping discussions, tasks, and project movement inside an organized academic flow.")</p>
                </article>

                <article class="feature-spotlight">
                    <span class="feature-spotlight__kicker">@T.T("Project planning")</span>
                    <h3>@T.T("From topic selection to task management")</h3>
                    <p>@T.T("Move from choosing project directions to assigning and managing work with better visibility and less confusion.")</p>
                </article>

                <article class="feature-spotlight feature-spotlight--expanded">
                    <span class="feature-spotlight__kicker">@T.T("Evaluation and progress")</span>
                    <h3>@T.T("Track quizzes, milestones, and outcomes clearly")</h3>
                    <p>@T.T("Keep academic progress easy to monitor with structured checkpoints, quizzes, and readable progress signals.")</p>
                </article>

                <article class="feature-spotlight feature-spotlight--accent">
                    <span class="feature-spotlight__kicker">@T.T("Role-aware workflow")</span>
                    <h3>@T.T("Built for students and professors together")</h3>
                    <p>@T.T("Role-based access, clearer responsibilities, and professor-student interaction make the platform feel more intentional and easier to use.")</p>
                </article>
            </div>

            <div class="feature-support" aria-label="Additional platform capabilities">
                <span>@T.T("Topic selection")</span>
                <span>@T.T("Task ownership")</span>
                <span>@T.T("Teamwork spaces")</span>
                <span>@T.T("Professor interaction")</span>
                <span>@T.T("Live notifications")</span>
                <span>@T.T("Progress tracking")</span>
            </div>
        </div>
    </section>

    <section class="section-block" id="workflow">
        <div class="home-shell">
            <div class="section-heading section-heading--centered">
                <span class="section-kicker">@T.T("How it works")</span>
                <h2>@T.T("A clear path from account creation to live academic coordination.")</h2>
                <p>@T.T("The workflow stays simple and readable so users understand the platform quickly and move into meaningful work without friction.")</p>
            </div>

            <ol class="journey-grid">
                <li class="journey-step">
                    <span class="journey-step__number">01</span>
                    <h3>@T.T("Create an account")</h3>
                    <p>@T.T("Students and professors enter through a straightforward account setup experience.")</p>
                </li>
                <li class="journey-step">
                    <span class="journey-step__number">02</span>
                    <h3>@T.T("Enter with the right role")</h3>
                    <p>@T.T("Each user lands in a role-aware environment shaped around academic responsibilities.")</p>
                </li>
                <li class="journey-step">
                    <span class="journey-step__number">03</span>
                    <h3>@T.T("Manage or join academic work")</h3>
                    <p>@T.T("Start projects, choose topics, form groups, and organize the work that needs to happen.")</p>
                </li>
                <li class="journey-step">
                    <span class="journey-step__number">04</span>
                    <h3>@T.T("Collaborate in real time")</h3>
                    <p>@T.T("Keep communication, tasks, decisions, and guidance moving inside one shared space.")</p>
                </li>
                <li class="journey-step">
                    <span class="journey-step__number">05</span>
                    <h3>@T.T("Follow progress and evaluation")</h3>
                    <p>@T.T("Track quizzes, milestones, and updates so momentum stays visible and manageable.")</p>
                </li>
            </ol>
        </div>
    </section>

    <section class="section-block section-block--benefits" id="benefits">
        <div class="home-shell benefits-layout">
            <div class="benefits-copy">
                <span class="section-kicker">@T.T("Why CollabSpace")</span>
                <h2>@T.T("A more organized academic environment leads to better coordination and fewer lost details.")</h2>
                <p>@T.T("CollabSpace is valuable because it makes academic collaboration easier to understand, easier to manage, and easier to keep moving.")</p>

                <div class="benefits-points">
                    <div class="benefits-points__item">
                        <strong>@T.T("Centralized collaboration")</strong>
                        <p>@T.T("Project work, communication, feedback, and progress stay connected instead of scattered across separate tools.")</p>
                    </div>
                    <div class="benefits-points__item">
                        <strong>@T.T("Clearer structure")</strong>
                        <p>@T.T("Students and professors can see responsibilities, progress, and next steps with much less ambiguity.")</p>
                    </div>
                </div>
            </div>

            <div class="benefits-showcase">
                <div class="benefits-showcase__header">
                    <span class="benefit-stat__label">@T.T("Platform value")</span>
                    <h3>@T.T("Why teams work better with a shared academic system")</h3>
                </div>

                <div class="benefit-rail">
                    <article class="benefit-rail__item">
                        <span class="benefit-rail__number">01</span>
                        <div>
                            <h4>@T.T("Better organization across the full workflow")</h4>
                            <p>@T.T("From topic selection to task completion, the platform keeps academic work connected in one clear path.")</p>
                        </div>
                    </article>

                    <article class="benefit-rail__item">
                        <span class="benefit-rail__number">02</span>
                        <div>
                            <h4>@T.T("Faster communication with less friction")</h4>
                            <p>@T.T("Professor-student interaction and live notifications make it easier to respond at the right time.")</p>
                        </div>
                    </article>

                    <article class="benefit-rail__item">
                        <span class="benefit-rail__number">03</span>
                        <div>
                            <h4>@T.T("Clearer progress and more efficient management")</h4>
                            <p>@T.T("Tasks, quizzes, milestones, and live updates help teams stay aligned without extra overhead.")</p>
                        </div>
                    </article>
                </div>
            </div>
        </div>
    </section>

    <section class="section-block section-block--cta">
        <div class="home-shell">
            <div class="cta-panel">
                <div class="cta-copy">
                    <span class="section-kicker">@T.T("Get started")</span>
                    <h2>@T.T("Bring structure, live coordination, and academic clarity into one premium platform.")</h2>
                    <p>@T.T("Sign in to continue your work or create an account to start using CollabSpace with your students, professors, and teams.")</p>
                </div>
            </div>
        </div>
    </section>
</div>

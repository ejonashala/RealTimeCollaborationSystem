@using RealTimeCollaborationSystem.Services.Interfaces
@inject ITranslationService T

@{
    ViewData["Title"] = @T.T("Projects");
}

<section class="dashboard-grid dashboard-grid--two">
    <article class="dashboard-card">
        <p class="dashboard-card__label">@T.T("Topic alignment")</p>
        <h3>@T.T("Shared project direction")</h3>
        <p>@T.T("Keep titles, scope, deliverables, and team ownership clearly documented.")</p>
    </article>

    <article class="dashboard-card">
        <p class="dashboard-card__label">@T.T("Progress")</p>
        <h3>@T.T("Milestones and deadlines")</h3>
        <p>@T.T("Track what is on schedule, what needs review, and what is ready to move forward.")</p>
    </article>
</section>

@model IEnumerable<RealTimeCollaborationSystem.Models.TopicBatch>
@using RealTimeCollaborationSystem.Services.Interfaces
@inject ITranslationService T

@{
    ViewData["Title"] = "Select Topic";
    var batches = Model?.ToList() ?? new List<RealTimeCollaborationSystem.Models.TopicBatch>();
    var currentStudentId = ViewBag.CurrentStudentId as int?;
    var pendingRequestBatchIds = ViewBag.PendingRequestBatchIds as HashSet<int> ?? new HashSet<int>();
    var acceptedBatchIds = ViewBag.AcceptedBatchIds as HashSet<int> ?? new HashSet<int>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/professor-topics.css" asp-append-version="true" />
}

<section class="dashboard-pagehead topics-head">
    <div>
        <p class="dashboard-kicker">@T.T("Faculty Projects")</p>
        <h2>@T.T("Topics")</h2>
        <p class="dashboard-lead">@T.T("Review groups after you request to join or after your request is accepted.")</p>
    </div>
</section>

@Html.AntiForgeryToken()

<div class="topic-selection-message" data-topic-selection-message aria-live="polite"></div>

@if (!batches.Any())
{
    <section class="topics-card">
        <div class="topics-empty">
            <h4>@T.T("No groups yet")</h4>
            <p>@T.T("Search for professors in Groups and send a join request. Requested or accepted groups will appear here.")</p>
        </div>
    </section>
}
else
{
    <section class="topic-batch-list" data-topic-selection-page>
        @foreach (var batch in batches)
        {
            var topics = batch.Topics.OrderBy(topic => topic.Title).ToList();
            var takenTopicsCount = topics.Count(topic =>
                topic.ReservedByStudentId.HasValue
                || string.Equals(topic.Status, "Taken", StringComparison.OrdinalIgnoreCase));
            var availableTopicsCount = topics.Count - takenTopicsCount;
            var professorName = string.IsNullOrWhiteSpace(batch.CreatedByProfessor?.Name)
                ? T.T("Professor not assigned")
                : batch.CreatedByProfessor.Name;
            var selectedTopicInBatch = currentStudentId.HasValue
                ? topics.FirstOrDefault(topic => topic.ReservedByStudentId == currentStudentId.Value)
                : null;
            var hasSelectedTopicInBatch = selectedTopicInBatch != null;
            var isAcceptedGroup = acceptedBatchIds.Contains(batch.Id);
            var isJoinedGroup = isAcceptedGroup || hasSelectedTopicInBatch;
            var isPendingRequest = pendingRequestBatchIds.Contains(batch.Id) && !isJoinedGroup;
            var isActiveGroup = isJoinedGroup;

            <article class="topics-card topic-batch topic-batch--academic @(isPendingRequest ? "topic-batch--pending-request" : "")" data-topic-batch-id="@batch.Id" data-selected-topic-id="@(selectedTopicInBatch?.Id.ToString() ?? string.Empty)">
                <div class="topic-batch__head">
                    <div class="topic-batch__main">
                        <p class="dashboard-kicker">@T.T("Group")</p>
                        <h3>@batch.Title</h3>
                        <div class="topic-batch__meta">
                            <span>
                                <strong>@T.T("Professor")</strong>
                                @professorName
                            </span>
                            <span>
                                <strong>@T.T("Open spots")</strong>
                                @availableTopicsCount
                            </span>
                        </div>
                        <p class="topics-card__text topic-batch__summary">
                            @if (!string.IsNullOrWhiteSpace(batch.Description))
                            {
                                @batch.Description
                            }
                            else if (isPendingRequest)
                            {
                                <span>@T.T("Your request is pending. Topics become active after acceptance.")</span>
                            }
                            else
                            {
                                <span>@T.T("Your group is active. Review your selected topic and available options.")</span>
                            }

                            @if (hasSelectedTopicInBatch)
                            {
                                <span class="topic-batch__selection">@T.T("Selected"): @selectedTopicInBatch!.Title</span>
                            }
                        </p>
                    </div>

                    <aside class="topic-batch__side" aria-label="Topic group summary">
                        <span class="topics-badge @(isActiveGroup ? "topics-badge--active" : "topics-badge--pending")">
                            @(isActiveGroup ? T.T("Joined") : T.T("Requested"))
                        </span>

                        <div class="topic-batch__stats">
                            <div class="topic-batch__stat topic-batch__stat--available">
                                <strong data-topic-count="available">@availableTopicsCount</strong>
                                <span>@T.T("Open")</span>
                            </div>
                            <div class="topic-batch__stat topic-batch__stat--taken">
                                <strong data-topic-count="taken">@takenTopicsCount</strong>
                                <span>@T.T("Filled")</span>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(batch.AttachmentPath))
                        {
                            <a class="dashboard-card__button topic-batch__file" href="@batch.AttachmentPath" download="@batch.AttachmentFileName">@T.T("Download file")</a>
                        }
                    </aside>
                </div>

                @if (isPendingRequest)
                {
                    <div class="topics-empty topic-batch__pending-note">
                        <h4>@T.T("Request pending")</h4>
                        <p>@T.T("This group is visible because you sent a join request. It will become active when the professor accepts you into the group.")</p>
                    </div>
                }
                else
                {
                    <div class="topic-grid">
                        @foreach (var topic in topics)
                        {
                            var isTaken = topic.ReservedByStudentId.HasValue
                                || string.Equals(topic.Status, "Taken", StringComparison.OrdinalIgnoreCase);
                            var isSelectedByCurrentStudent = currentStudentId.HasValue
                                && topic.ReservedByStudentId == currentStudentId.Value;
                            var shouldDisableSelect = isTaken
                                || (hasSelectedTopicInBatch && !isSelectedByCurrentStudent);
                            var shouldShowSelect = !isSelectedByCurrentStudent;
                            var buttonText = isSelectedByCurrentStudent
                                ? "Selected"
                                : hasSelectedTopicInBatch
                                    ? "Already selected"
                                    : "Select Topic";
                            var statusBadgeClass = isSelectedByCurrentStudent
                                ? "topics-badge--selected"
                                : isTaken
                                    ? "topics-badge--taken"
                                    : "topics-badge--live";

                            <article class="topic-card @(isTaken ? "is-taken" : "") @(isSelectedByCurrentStudent ? "is-selected" : "")" data-topic-card data-topic-id="@topic.Id">
                                <div class="topic-card__content">
                                    <div class="topic-card__title-row">
                                        <h4>@topic.Title</h4>
                                        <span class="topics-badge @statusBadgeClass" data-topic-status>
                                            @(isSelectedByCurrentStudent ? T.T("Selected") : isTaken ? T.T("Filled") : T.T("Available"))
                                        </span>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(topic.Description))
                                    {
                                        <p class="topic-card__description">@topic.Description</p>
                                    }
                                </div>

                                <div class="topic-card__actions">
                                    <button
                                        type="button"
                                        class="dashboard-card__button dashboard-card__button--primary @(shouldShowSelect ? "" : "is-hidden")"
                                        data-select-topic
                                        data-select-url="@Url.Action("SelectTopic", "StudentTopics", new { id = topic.Id })"
                                        @(shouldDisableSelect ? "disabled" : "")>
                                        @T.T(buttonText)
                                    </button>

                                    <button
                                        type="button"
                                        class="dashboard-card__button topic-release-button @(isSelectedByCurrentStudent ? "" : "is-hidden")"
                                        data-release-topic
                                        data-release-url="@Url.Action("ReleaseTopic", "StudentTopics", new { id = topic.Id })">
                                        @T.T("Release Topic")
                                    </button>
                                </div>
                            </article>
                        }
                    </div>
                }
            </article>
        }
    </section>
}

@section Scripts {
    <script src="~/js/student-topic-selection.js" asp-append-version="true"></script>
}

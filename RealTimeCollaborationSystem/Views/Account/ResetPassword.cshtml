@model RealTimeCollaborationSystem.Models.Dtos.ResetPasswordDto
@using RealTimeCollaborationSystem.Services.Interfaces
@inject ITranslationService T

@{
    ViewData["Title"] = "Reset Password";
    Layout = "_AuthLayout";
}

<link rel="stylesheet" href="~/css/login.css" />

<div class="login-container">
    <div class="login-box">
        <div class="login-header">
            <h1>CollabSpace</h1>
            <p>@T.T("Set your new password")</p>
        </div>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />

            <!-- NEW PASSWORD -->
            <div class="input-group">
                <label for="NewPassword">
                    <i class="fa fa-lock"></i> @T.T("New password")
                </label>

                <div class="password-box">
                    <input asp-for="NewPassword"
                           type="password"
                           id="NewPassword"
                           placeholder="@T.T("Enter your new password")" />

                    <i class="fa fa-eye-slash eye-toggle"
                       data-target="NewPassword"></i>
                </div>

                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <!-- CONFIRM PASSWORD -->
            <div class="input-group">
                <label for="ConfirmPassword">
                    <i class="fa fa-lock"></i> @T.T("Confirm password")
                </label>

                <div class="password-box">
                    <input asp-for="ConfirmPassword"
                           type="password"
                           id="ConfirmPassword"
                           placeholder="@T.T("Repeat your new password")" />

                    <i class="fa fa-eye-slash eye-toggle"
                       data-target="ConfirmPassword"></i>
                </div>

                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="login-btn">
                @T.T("Change password")
            </button>
        </form>

        <div asp-validation-summary="All" class="login-error"></div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".eye-toggle").forEach(icon => {
            icon.addEventListener("click", function () {
                const input = document.getElementById(this.dataset.target);
                if (!input) return;

                const show = input.type === "password";
                input.type = show ? "text" : "password";

                this.classList.toggle("fa-eye", show);
                this.classList.toggle("fa-eye-slash", !show);
            });
        });
    </script>
}

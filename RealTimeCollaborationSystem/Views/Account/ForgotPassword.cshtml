@using RealTimeCollaborationSystem.Services.Interfaces
@inject ITranslationService T

@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AuthLayout";
}

<link rel="stylesheet" href="~/css/login.css" />

<div class="login-container">
    <div class="login-box">
        <div class="login-header">
            <h1>CollabSpace</h1>
            <p>@T.T("Reset your password")</p>
        </div>

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()

            <div class="input-group">
                <label><i class="fa fa-envelope"></i> @T.T("Email")</label>
                <input name="Email" placeholder="@T.T("Enter your email")" required />
            </div>

            <button type="submit" class="login-btn">
                @T.T("Continue")
            </button>
        </form>

        <p class="signup-link">
            <a asp-action="Login">@T.T("Back to Login")</a>
        </p>
    </div>
</div>
